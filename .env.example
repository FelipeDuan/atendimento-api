# Copie para .env e ajuste (gitignored; carregado pelo bootRun).

# Spring
SPRING_PROFILES_ACTIVE=dev

# Banco de dados
POSTGRES_DB=atendimento
POSTGRES_USER=atendimento
POSTGRES_PASSWORD=trocar
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Runtime da aplicação
APP_DB_USER=atendimento_app
APP_DB_PASSWORD=atendimento

FLYWAY_USER=atendimento
FLYWAY_PASSWORD=trocar

# Redis
REDIS_PORT=6379

# Administrador da plataforma
PLATFORM_ADMIN_EMAIL=admin@plataforma.local
PLATFORM_ADMIN_NOME="Administrador da Plataforma"
PLATFORM_ADMIN_PASSWORD=trocar

# JWT (obrigatório)
JWT_SECRET=adotar-um-secret-com-pelo-menos-32-caracteres
JWT_EXPIRATION_MINUTES=15

# Webhook (obrigatórios; valores locais de referência)
# Ver docs/guides/verification-scalar.md
META_APP_SECRET=dev-meta-app-secret-change-me
META_VERIFY_TOKEN=dev-verify-token
